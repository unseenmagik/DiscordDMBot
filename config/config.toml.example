[discord]
# Discord bot token from the Discord developer portal.
bot_token = "replace-with-your-bot-token"

# One or more guilds where the bot is allowed to operate.
guild_ids = ["123456789012345678"]

# Only members with one of these role IDs can use the slash commands.
allowed_role_ids = ["345678901234567890"]

# Bot-owned admin channel for status posts and late reminder buttons.
admin_channel_id = "456789012345678901"

[runtime]
# Timezone used when calculating scheduled reminder times.
timezone = "Europe/London"

# How often the bot checks for due reminders.
poll_interval_seconds = 15

# If false, old reminders missed during downtime are skipped on restart.
# If true, the bot will catch up missed reminders after it comes back online.
send_missed_deliveries = false

# Where delivered reminder state is stored.
state_path = "data/delivery-state.json"

[embed]
# Shared embed styling used for reminder sends.
# This section controls the default look of the embeds the bot sends.
# It does not schedule messages by itself.
title = "Scheduled Reminder"
description_template = "Hello {{user}},\n\nThis is your payment reminder.\n\nValue: **{{value}}**\nDue: **{{due}}**"
footer = "Sent automatically by the Discord DM Bot"
color = "#C53030"
initial_color = "#2F855A"
final_color = "#DD6B20"
due_color = "#C53030"
late_color = "#C53030"
one_off_color = "#b630c5"

# Each [[deliveries]] block is one payment/reminder group for one user.
# Think of this as the parent payment record, not the actual messages.
# The user_id, due_date, due_time, frequency, and value below apply to every
# [[deliveries.reminders]] block that follows until the next [[deliveries]].
# Available frequency values: "once", "daily", "weekly", "bi-weekly", "monthly"
# If frequency is omitted, it defaults to "once".
[[deliveries]]
id = "payment-reminder-001"
user_id = "123456789012345678"
due_date = "2026-04-15"
due_time = "17:00"
frequency = "monthly"
value = "INV-2026-001"

# This reminder belongs to the [[deliveries]] block directly above.
[[deliveries.reminders]]
id = "initial"
name = "Initial Reminder"
title = "MPMaps Initial Payment Reminder"
days_before_due = 3
time = "09:00"
message = "Hello,\n\nThis is your **initial reminder** that payment **{{value}}** is due on **{{dueDate}}**."

# This reminder also belongs to the same [[deliveries]] block above.
[[deliveries.reminders]]
id = "final"
name = "Final Reminder"
title = "MPMaps Final Payment Reminder"
days_before_due = 1
time = "09:00"
message = "Hello,\n\nThis is your **final reminder** that payment **{{value}}** is due on **{{dueDate}}**."

# This is the on-the-day reminder and is the admin post that gets the
# "Late reminder" button when a matching `late` reminder exists.
[[deliveries.reminders]]
id = "due"
name = "Due Reminder"
title = "MPMaps Payment Due Today"
days_before_due = 0
time = "09:00"
message = "Hello {{user}},\n\nYour payment is due today.\n\nValue: **{{value}}**\nDue: **{{due}}**"

# A manual-only late reminder. This is not scheduled automatically.
# The bot can send it from the admin channel when the "Late reminder" button is used
# on the `due` reminder admin post.
[[deliveries.reminders]]
id = "late"
name = "Late Reminder"
title = "MPMaps Late Payment Reminder"
message = "Hello {{user}},\n\nYour payment is now overdue.\n\nValue: **{{value}}**\nDue: **{{due}}**"

# Start a new [[deliveries]] block when you want reminders for a different
# user or a different payment/value.
# Available frequency values for reminder schedules: "once", "daily", "weekly",
# "bi-weekly", "monthly"
[[deliveries]]
id = "one-off-example"
user_id = "234567890123456789"
date = "2026-04-16"
time = "14:45"
message = "Hello,\n\nYour custom one-off reminder is ready.\n\nReference: **{{value}}**"
value = "INV-2026-002"
